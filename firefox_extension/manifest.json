{
  "manifest_version": 2,
  "name": "WebReranker",
  "version": "1.0",
  "description": "Reorder search results to prioritize informative content",
  "permissions": [
    "activeTab",
    "storage",
    "http://127.0.0.1/*",
    "https://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_title": "WebReranker",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    "selectors.json"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}
